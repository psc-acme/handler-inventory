{
    "name": "psc-acme/handler-inventory",
    "description": "Package handler-inventory for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HandlerInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/lock": "^7.0",
        "symfony/symfony": "^6.3",
        "psc-acme/renderer-product": "^1.0",
        "psc-acme/middleware-catalog": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}